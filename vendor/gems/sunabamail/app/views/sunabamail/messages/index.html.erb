<p style="color: green"><%= notice %></p>

<% content_for :title, "Messages" %>

<h1>Messages</h1>

<div id="messages">
  <% @messages.each do |message| %>
    <% mail = message.mail %>
    <dl>
      <dt>Date</dt>
      <dd><%= l mail.date, format: :short %></dd>
      <dt>Message ID</dt>
      <dd><%= mail.message_id %></dd>
      <dt>Subject</dt>
      <dd><%= mail.subject %></dd>
    </dl>
    <p>
      <%= link_to "Show this message", message_path(message) %>
    </p>
    <hr>
  <% end %>
</div
