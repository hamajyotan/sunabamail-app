<p style="color: green"><%= notice %></p>

<h1>Messages</h1>

<%= button_to "Reload", messages_path, method: :get %>
<%= button_to "Delete all", messages_all_path, method: :delete, disabled: @messages.blank?, data: { turbo_confirm: "OK?" } %>

<div id="messages">
  <% @messages.each do |message| %>
    <% mail = message.mail %>
    <div>
      <p><%= mail.subject %></p>
      <p>
        <span>To</span><span><%= mail.to.join(', ') %></span>
        <span><%= time_ago_in_words mail.date %></span>
      </p>
      <p><%= link_to "Show this message", message_path(message) %></p>
    <div>
    <hr>
  <% end %>
</div
