<div id="<%= dom_id object %>">
  <% mail = object.mail %>
  <div>
    <h2><%= mail.subject %></h2>

    <dl>
      <dt>From</dt>
      <dd><%= mail.from.join(', ') %></dd>

      <% if mail.to.present? %>
        <dt>To</dt>
        <dd><%= mail.to.join(', ') %></dd>
      <% end %>

      <% if mail.cc.present? %>
        <dt>Cc</dt>
        <dd><%= mail.cc.join(', ') %></dd>
      <% end %>

      <% if mail.bcc.present? %>
        <dt>Bcc</dt>
        <dd><%= mail.bcc.join(', ') %></dd>
      <% end %>

      <% if mail.reply_to.present? %>
        <dt>Reply-To</dt>
        <dd><%= mail.reply_to.join(', ') %></dd>
      <% end %>

      <dt>Date</dt>
      <dd><%= l mail.date, format: :long %></dd>
    </dl>

    <% if mail.html_part.present? %>
      <h3>Html</h3>
      <%= tag.iframe sealmess: "sealmess", src: message_html_path(object) %>

      <h3>Html source</h3>
      <%= tag.iframe sealmess: "sealmess", src: message_source_path(object) %>
    <% end %>

    <% if mail.text_part.present? %>
      <h3>Text</h3>
      <div>
        <%= tag.iframe sealmess: "sealmess", src: message_text_path(object) %>
      </div>
    <% end %>

    <h3>Raw</h3>
    <div>
      <%= tag.iframe sealmess: "sealmess", src: message_raw_path(object) %>
    </div>

    <% mail.attachments.each.with_index do |attachment, index| %>
      <%= link_to attachment.filename, message_attachment_path(object, index), download: true %>
    <% end %>
  </div>
</div>
